# Copy this file to `.env` (which is gitignored) and fill in your real values.
# All values are optional; sensible placeholders are used when unset.

# --- Applicant details (used by the local auto-apply form filler) ---
APPLICANT_FIRST_NAME=
APPLICANT_LAST_NAME=
APPLICANT_FULL_NAME=
APPLICANT_EMAIL=
APPLICANT_PHONE=
APPLICANT_LOCATION=
APPLICANT_LINKEDIN=
APPLICANT_GITHUB=
# Google/Workday sign-in email for "Use My Last Application" (defaults to APPLICANT_EMAIL)
APPLICANT_WORKDAY_EMAIL=
# Absolute path to the résumé attached to applications
APPLICANT_RESUME_PATH=

# --- Screening-answer defaults ---
APPLICANT_EMPLOYER=
APPLICANT_TITLE=
APPLICANT_YOE=
# Set to "male"/"female" to auto-answer gender questions; leave blank to decline
APPLICANT_GENDER=

# --- Admin portal (private analytics at /adminpage) ---
ADMIN_USER=admin
# scrypt hash string ("scrypt$<salt>$<dk>"); generate with hashPassword() in admin.js
ADMIN_PASS_HASH=
# HMAC secret for signing admin session cookies (use a long random string)
ADMIN_SESSION_SECRET=
# Where password-reset emails are sent
ADMIN_RESET_EMAIL=

# --- Feedback admin token (append ?token=... to /api/feedback to see contact info) ---
FEEDBACK_ADMIN_TOKEN=

# --- SMTP (for admin password-reset emails; Gmail App Password works) ---
SMTP_USER=
SMTP_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=

# --- Runtime ---
# PORT=5179
# DATA_DIR=./server/data
